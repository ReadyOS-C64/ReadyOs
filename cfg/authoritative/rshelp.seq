READYSHELL QUICK REF! TYPES THE | PIPE ON C64 KEYBOARDUSE: CAT "RSHELP" | MORECLEAR - REDRAW SHELL  CLEARLST - LIST FILES  LST 9  LST "9:T*"  LST "T?",9  LST "T*",9,"SEQ,PRG"DRVI - DRIVE INFO  DRVI 9CAT - READ TEXT  CAT "9:NOTES"COPY - COPY FILE  COPY "8:NOTES","9:NOTES2"REN - RENAME FILE  REN "OLD","NEW",9DEL - SCRATCH FILE  DEL "9:NOTES"PUT - WRITE SEQ FILE  PUT $A,"9:NOTES"ADD - APPEND SEQ FILE  ADD $A,"9:NOTES"PRT - PRINT VALUE  PRT "HI",5MORE - PAGE EVERY 20 OR N ITEMS  GEN 40 | MORE  GEN 40 | MORE 10SEL - PICK FIELDS  LST | SEL "NAME"  LST | SEL "NAME","BLOCKS"TOP - KEEP N ITEMS, SKIP M FIRST  LST | TOP 3  LST | TOP 3,1GEN - COUNT 1..N  GEN 5LDV - LOAD VALUE  $A=LDV "SNAP",9  $A=LDV "9:SNAP"STV - SAVE VALUE  STV $A,"SNAP",9  STV $A,"9:SNAP"HELP - SHOW HINT  HELPPIPELINE EXAMPLES  LST | PRT @.NAME  LST | ?[ @.TYPE=="PRG" ] | SEL "NAME"  LST | ?[ @.BLOCKS>10 ] | SEL "NAME","BLOCKS"  LST | %[ PRT @.NAME ; @ ] | TOP 3VARS AND INDEXING  $A=1..10  $DIR=LST | TOP 3  PRT $DIR(0).NAME  $SOME=$DIR | TOP 2,1  $NAMES=LST | TOP 3 | SEL "NAME"  PRT $NAMES(1)